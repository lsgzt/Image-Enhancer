# Copy this file to `.env` and fill in the real values. `.env` is
# gitignored, so the real token will never get committed.

# Telegram bot token from @BotFather. Used by the backend to send the
# processed photo to the user via the Telegram Bot API. Keep this SECRET.
TELEGRAM_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE

# (Optional) Override the default Flask secret key.
# FLASK_SECRET_KEY=change-me-to-a-long-random-string

# (Optional) Set to 1 to enable verbose request logging.
# FLASK_DEBUG=0
